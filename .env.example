# ─── Womo Environment Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# Generate JWT_SECRET with: node -e "require('crypto').randomBytes(32).toString('hex')"

# ─── Database (Supabase connection pooler URL) ────────────────────────────────
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-2.pooler.supabase.com:5432/postgres

# ─── API Keys ─────────────────────────────────────────────────────────────────

# Google AI Studio (Gemini 2.5 Flash LLM)
GEMINI_API_KEY=your-google-ai-studio-key

# Google Maps Places API
GOOGLE_MAPS_API_KEY=your-google-maps-key

# OpenAI Whisper transcription (optional — leave empty if not using)
# OPENAI_API_KEY=your-openai-key

# ─── Auth ─────────────────────────────────────────────────────────────────────

# 4-digit (or longer) pilot access PIN — shown on login screen
PIN_CODE=your-pilot-pin

# Secret used to HMAC-sign the auth cookie — must be long and random
# Generate: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=generate-with-node-e-require-crypto-randomBytes-32-toString-hex

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In Railway production, set this to your Vercel deployment URL.
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
# Railway injects PORT automatically — set to 8080 to match Dockerfile EXPOSE
PORT=8080
